# --- App ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database / broker ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/codereviewai
REDIS_URL=redis://redis:6379/0

# --- GitHub App ---
# Create at: https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
GITHUB_APP_WEBHOOK_SECRET=change-me-to-a-random-webhook-secret

# --- AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_DIFF_CHARS=30000

# --- RAG (Qdrant) ---
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# --- SonarQube (off by default; see README before enabling) ---
SONARQUBE_ENABLED=false
SONARQUBE_URL=http://sonarqube:9000
SONARQUBE_TOKEN=

# --- Monitoring & notifications (Phase 7) ---
# Port the Celery worker serves Prometheus metrics on (separate from the
# backend, which serves its own at GET /metrics on its normal port).
WORKER_METRICS_PORT=9200
# Optional: post a message here when a review completes/fails or a Sonar
# quality gate fails. Leave blank to disable — this is independent of the
# Slack step in .github/workflows/docker-publish.yml, which notifies about
# this platform's own CI/CD, not about reviews of connected repos.
SLACK_WEBHOOK_URL=

# --- Frontend (read by apps/frontend at build/runtime) ---
# Must be reachable from the browser, so use localhost, not the "backend"
# docker-compose service name.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GITHUB_APP_SLUG=
