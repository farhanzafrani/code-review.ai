# --- App ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database / broker ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/codereviewai
REDIS_URL=redis://redis:6379/0

# --- GitHub App ---
# Create at: https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
GITHUB_APP_WEBHOOK_SECRET=change-me-to-a-random-webhook-secret

# --- AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_DIFF_CHARS=30000

# --- RAG (Qdrant) ---
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# --- Frontend (read by apps/frontend at build/runtime) ---
# Must be reachable from the browser, so use localhost, not the "backend"
# docker-compose service name.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GITHUB_APP_SLUG=
